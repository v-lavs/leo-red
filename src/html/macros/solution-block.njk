{% macro solutionBlock(data) %}
    <article class="overview-card solution-block">

        <div class="overview-card__header">
            <div class="overview-card__icon">
                <img src="img/{{ data.icon }}" alt="">
            </div>
            <h3 class="overview-card__title">{{ data.title }}</h3>
        </div>

        <div class="overview-card__content">
            <div class="overview-card__description dynamic-content">
                    {% if data.paragraphs %}
                        {% for paragraph in data.paragraphs %}
                            <p>{{ paragraph }}</p>
                        {% endfor %}
                    {% endif %}

                    {% if data.benefits and data.benefits.length > 0 %}
                        <p>{{ data.benefitsTitle | default('Основні переваги:') }}</p>
                        <ul>
                            {% for benefit in data.benefits %}
                                <li>{{ benefit }}</li>
                            {% endfor %}
                        </ul>
                    {% endif %}
                </div>

                {% if data.image %}
                    <div class="overview-card__image-wrap">
                        <img src="{{ data.image }}" alt="{{ data.title }}" class="overview-card__image">
                    </div>
                {% endif %}

            </div>
    </article>
{% endmacro %}

