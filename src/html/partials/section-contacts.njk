<section class="section section-contacts">
            <div class="container">
                <div class="section__heading">
                    <h1 class="staggered-heading">
                        <span class="staggered-heading__line">Готові будувати ваш</span>
                        <span class="staggered-heading__line">бізнес з нами?</span>
                    </h1>
                </div>
                <div class="d-flex">
                    <div class="section__part section__part-left">
                        <form action="#" method="post" name="contact-form" class="form-contacts">
                            <div class="form-group">
                                <label for="firstName">
                                    <input class="input" id="firstName" type="text" name="firstName" autocomplete="name" placeholder="Введіть ваше ПІБ">
                                </label>
                            </div>
                            <div class="form-group">
                                <label class="label" for="phoneNumber">
                                    <input class="input" id="phoneNumber" type="tel" name="phone-number" placeholder="Ваш номер телефону">
                                </label>
                            </div>
                            <div class="form-group">
                                <label class="label" for="descriptionContact">
                                    <input class="input" id="descriptionContact" type="text" name="description" placeholder="Ваше повідомлення">
                                </label>
                            </div>
                            <button type="submit" class="btn btn_main btn_border btn_dark btn_submit">
                                <span class="icon">
                                    <img src="images/icons/arrow-prev.svg" alt="" aria-hidden="true">
                                </span>Звязатись з нами
                            </button>
                        </form>
                    </div>
                    <div class="section__part section__part-right">
                        <div class="contacts__list">
                            <div class="contacts__item">
                                <h3>Адреса: </h3>
                                <div class="contacts__content">Україна, м. Львів, вул. Довбуша 7а/5</div>
                            </div>
                            <div class="contacts__item">
                                <h3>Телефони: </h3>
                                <div class="contacts__content">
                                    <a href="tel:+38066984240">+38 066 984 24 02</a>
                                    <a href="tel:+380679834655">+38 067 983 46 55</a>
                                </div>
                            </div>
                            <div class="contacts__item">
                                <h3>Електронна пошта: </h3>
                                <div class="contacts__content">info@leonix.com.ua</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
    </section>